<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- MARK: Privacy Descriptions (App Store zorunlu) -->

    <!-- Sesli analiz özelliği: Argus sesli komutları ve raporları için mikrofon kullanır -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Argus, sesli komutları dinlemek ve borsa analizini sesli okumak için mikrofonu kullanır.</string>

    <!-- Konuşma tanıma: Sesli komutları metne dönüştürmek için -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Argus, sesli komutlarınızı tanımak ve portföy sorgularını anlamak için konuşma tanıma kullanır.</string>

    <!-- Bildirimler: Fiyat alarmları ve sinyal bildirimleri -->
    <key>NSUserNotificationUsageDescription</key>
    <string>Argus, fiyat alarmları, stop-loss uyarıları ve önemli piyasa sinyalleri için bildirim gönderir.</string>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- MARK: BorsaPy Backend Config (Secrets.xcconfig'ten substitute edilir) -->
    <!--
        BORSAPY_URL: BIST veri sağlayıcısının URL'i (HTTPS önerilir, lokal dev'de http://localhost:8899).
        BORSAPY_KEY: Backend'e Bearer token koyulduysa aynı değer (boş bırakılabilir).

        ÖNEMLİ: pbxproj'daki `INFOPLIST_KEY_<custom>` ayarları SADECE Apple'ın tanıdığı
        sistem key'leri (orientations, usage descriptions) için inject olur — custom
        key'ler için bu placeholder yöntemi şarttır. Yeni secret eklerken hem
        Secrets.xcconfig'e hem buraya `<key>X</key><string>$(X)</string>` yaz.

        Bu placeholder yokken: Secrets.borsaPyURL boş döner → BorsaPyProvider devre
        dışı → BIST tüm sembolleri sessizce Yahoo fallback'e düşer.
    -->
    <key>BORSAPY_URL</key>
    <string>$(BORSAPY_URL)</string>
    <key>BORSAPY_KEY</key>
    <string>$(BORSAPY_KEY)</string>
</dict>
</plist>
